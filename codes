        { de: "präsentieren", en: "to present", type: "verb", difficulty: "easy" },
        { de: "teilnehmen (an)", en: "to participate (in)", type: "verb", difficulty: "easy" },
        { de: "vereinbaren", en: "to arrange / agree upon", type: "verb", difficulty: "medium" },
        { de: "vertreten", en: "to represent", type: "verb", difficulty: "medium" },
        
        // High-Yield B2/C1 Nouns Added for Categorization
        { de: "die Auswirkung", en: "the impact / consequence", type: "noun", difficulty: "easy" },
        { de: "der Zusammenhang", en: "the connection / context", type: "noun", difficulty: "medium" },
        { de: "die Voraussetzung", en: "the prerequisite / requirement", type: "noun", difficulty: "hard" },
        { de: "der Bereich", en: "the area / field / sector", type: "noun", difficulty: "easy" },
        { de: "die Herausforderung", en: "the challenge", type: "noun", difficulty: "easy" },
        { de: "die Entwicklung", en: "the development", type: "noun", difficulty: "easy" },
        { de: "der Fortschritt", en: "the progress", type: "noun", difficulty: "medium" },
        { de: "die Maßnahme", en: "the measure / action steps", type: "noun", difficulty: "hard" },
        { de: "die Entscheidung", en: "the decision", type: "noun", difficulty: "easy" },
        { de: "die Verantwortung", en: "the responsibility", type: "noun", difficulty: "medium" },
        { de: "der Ursprung", en: "the origin", type: "noun", difficulty: "hard" },
        { de: "die Begründung", en: "the justification / rationale", type: "noun", difficulty: "medium" },
        { de: "die Untersuchung", en: "the investigation / study", type: "noun", difficulty: "hard" },
        { de: "der Anwalt", en: "the lawyer / attorney", type: "noun", difficulty: "easy" },
        { de: "die Vereinbarung", en: "the agreement / arrangement", type: "noun", difficulty: "medium" }
    ];

    // APPLICATION STATE VARIABLES
    let currentTab = "flashcards";
    let filterType = "all";
    let filterDiff = "all";
    
    let filteredPool = [];
    let activeCardIndex = 0;
    
    // TRACKING STATS
    let totalReviewedCount = 0;
    let knewItCount = 0;
    let missedArray = [];
    let currentMissedIndex = 0;

    // SPEED ROUND STATE
    let speedTimerInterval = null;
    let speedTimeLeft = 30;
    let speedScoreValue = 0;
    let speedCurrentWord = null;

    window.onload = () => {
        document.getElementById("total-pool-count").innerText = database.length;
        applyFilters();
    };

    // SYSTEM VIEW CONTROLLER Tabs
    function switchTab(tabId) {
        currentTab = tabId;
        
        // UI reset states
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
        
        event.target.classList.add('active');
        document.getElementById(tabId).classList.add('active');

        // Toggle global visibility parameters depending on selected system focus
        const filterPanel = document.getElementById("filter-panel");
        const statsPanel = document.getElementById("stats-grid");

        // Stop live interval runtime instances if navigation leaves active state execution
        clearInterval(speedTimerInterval);

        if (tabId === "speed") {
            filterPanel.style.display = "none";
            statsPanel.style.display = "none";
            resetSpeedRoundUI();
        } else if (tabId === "missed") {
            filterPanel.style.display = "none";
            statsPanel.style.display = "none";
            initMissedTrayView();
        } else {
            filterPanel.style.display = "block";
            statsPanel.style.display = "grid";
            applyFilters();
            if (tabId === "quiz") initQuizQuestion();
        }
    }

    // RUNTIME DATA STREAMS FILTER ENGINE
    function setWordTypeFilter(type, element) {
        setSelectedPill(element);
        filterType = type;
        applyFilters();
    }

    function setDifficultyFilter(diff, element) {
        setSelectedPill(element);
        filterDiff = diff;
        applyFilters();
    }

    function setSelectedPill(el) {
        const parent = el.parentElement;
        parent.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
        el.classList.add('active');
    }

    function applyFilters() {
        filteredPool = database.filter(item => {
            const matchesType = (filterType === "all" || item.type === filterType);
            const matchesDiff = (filterDiff === "all" || item.difficulty === filterDiff);
            return matchesType && matchesDiff;
        });

        activeCardIndex = 0;
        updateGlobalStatsDashboard();

        if (currentTab === "flashcards") {
            renderFlashcardView();
        } else if (currentTab === "quiz") {
            initQuizQuestion();
        }
    }

    function updateGlobalStatsDashboard() {
        document.getElementById("stat-reviewed").innerText = `${totalReviewedCount}/${filteredPool.length}`;
        document.getElementById("stat-knew").innerText = knewItCount;
        document.getElementById("stat-missed-count").innerText = missedArray.length;
    }

    // FLASHCARD EXECUTIVE LOGIC TRACER
    function renderFlashcardView() {
        const deckContainer = document.getElementById("fc-deck-container");
        const emptyState = document.getElementById("fc-empty-state");
        
        if (filteredPool.length === 0) {
            deckContainer.style.display = "none";
            emptyState.style.display = "block";
            return;
        }

        deckContainer.style.display = "block";
        emptyState.style.display = "none";

        const item = filteredPool[activeCardIndex];
        document.getElementById("fc-anim-target").classList.remove("flipped");

        // UI Tag strings updating pipeline 
        const typeTag = document.getElementById("fc-tag-type");
        const diffTag = document.getElementById("fc-tag-diff");
        const typeTagB = document.getElementById("fc-tag-type-b");

        typeTag.innerText = item.type;
        typeTag.className = `tag ${item.type}`;
        typeTagB.innerText = item.type;
        typeTagB.className = `tag ${item.type}`;

        diffTag.innerText = item.difficulty;
        diffTag.className = `tag ${item.difficulty}`;

        document.getElementById("fc-front-text").innerText = item.de;
        document.getElementById("fc-back-text").innerText = item.en;
    }

    function flipCard() {
        document.getElementById("fc-anim-target").classList.toggle("flipped");
    }

    function advanceDeckNextPointer() {
        if (filteredPool.length === 0) return;
        activeCardIndex = (activeCardIndex + 1) % filteredPool.length;
        totalReviewedCount++;
        updateGlobalStatsDashboard();
        renderFlashcardView();
    }

    function skipCard() {
        advanceDeckNextPointer();
    }

    function markCardKnew() {
        knewItCount++;
        advanceDeckNextPointer();
    }

    function markCardMissed() {
        const currentItem = filteredPool[activeCardIndex];
        if (!missedArray.some(item => item.de === currentItem.de)) {
            missedArray.push(currentItem);
        }
        advanceDeckNextPointer();
    }

    // MULTIPLE CHOICE EXAM QUIZ PIPELINE
    function initQuizQuestion() {
        const gameContainer = document.getElementById("quiz-game-container");
        const emptyState = document.getElementById("quiz-empty-state");
        const nextBtn = document.getElementById("quiz-next-btn");

        if (filteredPool.length === 0) {
            gameContainer.style.display = "none";
            emptyState.style.display = "block";
            return;
        }

        gameContainer.style.display = "block";
        emptyState.style.display = "none";
        nextBtn.style.display = "none";

        // Pick Random target from context stream pool array options
        const targetItem = filteredPool[Math.floor(Math.random() * filteredPool.length)];
        document.getElementById("quiz-word").innerText = targetItem.de;

        // Generate dynamic choice combinations 
        let options = [targetItem.en];
        while (options.length < 4 && options.length < database.length) {
            let randEn = database[Math.floor(Math.random() * database.length)].en;
            if (!options.includes(randEn)) options.push(randEn);
        }
        options.sort(() => Math.random() - 0.5);

        const optionsBox = document.getElementById("quiz-options");
        optionsBox.innerHTML = "";

        options.forEach(opt => {
            const button = document.createElement("button");
            button.className = "quiz-opt";
            button.innerText = opt;
            button.onclick = () => evaluateQuizSelection(button, opt, targetItem.en, ".quiz-opt", "quiz-next-btn", true);
            optionsBox.appendChild(button);
        });
    }

    function evaluateQuizSelection(selectedBtn, chosenValue, correctValue, classTarget, nextBtnId, trackMissedFlag) {
        const allButtons = document.querySelectorAll(classTarget);
        allButtons.forEach(btn => btn.disabled = true);

        if (chosenValue === correctValue) {
            selectedBtn.classList.add("correct");
            if (!trackMissedFlag) speedScoreValue += 2; // Extra speed point score logic allocations
        } else {
            selectedBtn.classList.add("wrong");
            allButtons.forEach(btn => {
                if (btn.innerText === correctValue) btn.classList.add("correct");
            });

            if (trackMissedFlag) {
                // Deduce target object pointer and move it straight into missed tracking bin
                const missingObj = database.find(i => i.en === correctValue);
                if (missingObj && !missedArray.some(m => m.de === missingObj.de)) {
                    missedArray.push(missingObj);
                }
            } else {
                // Penalty for errors during speed runs
                speedTimeLeft = Math.max(0, speedTimeLeft - 3);
                document.getElementById("speed-timer").innerText = speedTimeLeft;
            }
        }

        const nextControl = document.getElementById(nextBtnId);
        if (nextControl) nextControl.style.display = "block";
        if (!nextBtnId) {
            // Speed rounds automatically sequence dynamically via instant timeout delays
            setTimeout(() => { if (speedTimeLeft > 0) processNextSpeedItem(); }, 800);
        }
    }

    // HIGH-VELOCITY TIMED SPEED RUNNING MODULE
    function resetSpeedRoundUI() {
        document.getElementById("speed-start-panel").style.display = "block";
        document.getElementById("speed-game-panel").style.display = "none";
    }

    function startSpeedRound() {
        document.getElementById("speed-start-panel").style.display = "none";
        document.getElementById("speed-game-panel").style.display = "block";

        speedTimeLeft = 30;
        speedScoreValue = 0;
        document.getElementById("speed-score").innerText = speedScoreValue;
        document.getElementById("speed-timer").innerText = speedTimeLeft;

        processNextSpeedItem();

        speedTimerInterval = setInterval(() => {
            speedTimeLeft--;
            document.getElementById("speed-timer").innerText = speedTimeLeft;

            if (speedTimeLeft <= 0) {
                clearInterval(speedTimerInterval);
                concludeSpeedSession();
            }
        }, 1000);
    }

    function processNextSpeedItem() {
        if (database.length === 0) return;
        
        speedCurrentWord = database[Math.floor(Math.random() * database.length)];
        document.getElementById("speed-word").innerText = speedCurrentWord.de;

        let options = [speedCurrentWord.en];
        while (options.length < 4) {
            let randEn = database[Math.floor(Math.random() * database.length)].en;
            if (!options.includes(randEn)) options.push(randEn);
        }
        options.sort(() => Math.random() - 0.5);

        const optionsContainer = document.getElementById("speed-options");
        optionsContainer.innerHTML = "";

        options.forEach(opt => {
            const btn = document.createElement("button");
            btn.className = "quiz-opt";
            btn.innerText = opt;
            btn.onclick = () => {
                speedScoreValue++;
                document.getElementById("speed-score").innerText = speedScoreValue;
                evaluateQuizSelection(btn, opt, speedCurrentWord.en, "#speed-options .quiz-opt", null, false);
            };
            optionsContainer.appendChild(btn);
        });
    }

    function concludeSpeedSession() {
        alert(`🏁 Time's up! You completed the speed round with a final score of: ${speedScoreValue}`);
        resetSpeedRoundUI();
    }

    // WRONG / MISSED STUDY TRAY MODULES
    function initMissedTrayView() {
        const container = document.getElementById("missed-deck-container");
        const emptyState = document.getElementById("missed-empty-state");

        if (missedArray.length === 0) {
            container.style.display = "none";
            emptyState.style.display = "block";
            return;
        }

        container.style.display = "block";
        emptyState.style.display = "none";
        currentMissedIndex = 0;

        renderMissedCardItem();
    }

    function renderMissedCardItem() {
        if (missedArray.length === 0) {
            initMissedTrayView();
            return;
        }
        
        if (currentMissedIndex >= missedArray.length) currentMissedIndex = 0;
        const item = missedArray[currentMissedIndex];

        document.getElementById("missed-anim-target").classList.remove("flipped");

        const mType = document.getElementById("m-tag-type");
        const mDiff = document.getElementById("m-tag-diff");
        const mTypeB = document.getElementById("m-tag-type-b");

        mType.innerText = item.type;
        mType.className = `tag ${item.type}`;
        mTypeB.innerText = item.type;
        mTypeB.className = `tag ${item.type}`;
        
        mDiff.innerText = item.difficulty;
        mDiff.className = `tag ${item.difficulty}`;

        document.getElementById("m-front-text").innerText = item.de;
        document.getElementById("m-back-text").innerText = item.en;
    }

    function flipMissedCard() {
        document.getElementById("missed-anim-target").classList.toggle("flipped");
    }

    function nextMissedCard() {
        if (missedArray.length === 0) return;
        currentMissedIndex = (currentMissedIndex + 1) % missedArray.length;
        renderMissedCardItem();
    }

    function clearFromMissed() {
        if (missedArray.length === 0) return;
        missedArray.splice(currentMissedIndex, 1);
        renderMissedCardItem();
    }
</script>
